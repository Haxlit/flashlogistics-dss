@startuml diagrama_relacional_flashlogistics_compacto
title Sistema FlashLogistics DSS - Modelo Relacional Optimizado
hide circle

' ══════════════════════════════════
' CONFIGURACIÓN DE COMPRESIÓN GRÁFICA
' ══════════════════════════════════
skinparam ranksep 18
skinparam nodesep 18
skinparam shadowing false
skinparam class {
    BackgroundColor #F8FAFC
    BorderColor #475569
    HeaderBackgroundColor #4F46E5
    HeaderFontColor #FFFFFF
    FontName Arial
    FontSize 10
    AttributeFontSize 9
}

' ══════════════════════════════════
' PACKAGE: Usuarios y Roles
' ══════════════════════════════════
package "Usuarios y Roles" #F1F5F9 {
  entity USUARIO {
    * id : BIGINT <<PK>>
    --
    * nombre : VARCHAR(100) NOT NULL
    * email : VARCHAR(150) NOT NULL UNIQUE
    * password_hash : VARCHAR(255) NOT NULL
    * activo : BOOLEAN NOT NULL DEFAULT TRUE
    * creado_en : TIMESTAMP NOT NULL DEFAULT NOW()
    * tipo_usuario : VARCHAR(20) NOT NULL
  }

  entity PERMISO {
    * id : BIGINT <<PK>>
    --
    * codigo : VARCHAR(50) NOT NULL UNIQUE
    * modulo : VARCHAR(50) NOT NULL
    * accion : VARCHAR(50) NOT NULL
  }

  entity USUARIO_PERMISO {
    * usuario_id : BIGINT <<FK>>
    * permiso_id : BIGINT <<FK>>
  }

  entity GERENTE_OPERACIONES {
    * usuario_id : BIGINT <<PK, FK>>
    --
    * presupuesto_diario : DECIMAL(12,2) NOT NULL
  }

  entity DESPACHADORA {
    * usuario_id : BIGINT <<PK, FK>>
    --
    * turno : VARCHAR(10) NOT NULL
  }

  entity CONDUCTOR {
    * usuario_id : BIGINT <<PK, FK>>
    --
    * licencia : VARCHAR(20) NOT NULL UNIQUE
    * categoria_licencia : VARCHAR(5) NOT NULL
    calificacion : DECIMAL(3,2) DEFAULT 5.0
    * disponible : BOOLEAN NOT NULL DEFAULT TRUE
  }

  entity CLIENTE_MINORISTA {
    * usuario_id : BIGINT <<PK, FK>>
    --
    * ruc : VARCHAR(20) NOT NULL UNIQUE
    * razon_social : VARCHAR(200) NOT NULL
    * notif_preferencia : VARCHAR(10) NOT NULL DEFAULT 'NONE'
  }

  entity PREFERENCIA_NOTIFICACION {
    * id : BIGINT <<PK>>
    --
    * cliente_id : BIGINT <<FK>> NOT NULL
    * canal : VARCHAR(10) NOT NULL
    * activa : BOOLEAN NOT NULL DEFAULT TRUE
    * hora_desde : TIME NOT NULL
    * hora_hasta : TIME NOT NULL
  }

  USUARIO ||--o| GERENTE_OPERACIONES
  USUARIO ||--o| DESPACHADORA
  USUARIO ||--o| CONDUCTOR
  USUARIO ||--o| CLIENTE_MINORISTA
  USUARIO_PERMISO }o-left-|| USUARIO
  USUARIO_PERMISO }o-right-|| PERMISO
  CLIENTE_MINORISTA ||--|| PREFERENCIA_NOTIFICACION
}

' ══════════════════════════════════
' PACKAGE: Pedidos
' ══════════════════════════════════
package "Pedidos" #EFF6FF {
  entity PEDIDO {
    * id : BIGINT <<PK>>
    --
    * numero_pedido : VARCHAR(20) NOT NULL UNIQUE
    * fecha_creacion : TIMESTAMP NOT NULL DEFAULT NOW()
    * fecha_entrega : DATE NOT NULL
    * estado : VARCHAR(15) NOT NULL DEFAULT 'PENDIENTE'
    * prioridad : VARCHAR(10) NOT NULL DEFAULT 'MEDIA'
    * monto_total : DECIMAL(12,2) NOT NULL
    * cliente_id : BIGINT <<FK>> NOT NULL
    despachadora_id : BIGINT <<FK>>
    importacion_id : BIGINT <<FK>>
    * modificado_en : TIMESTAMP NOT NULL DEFAULT NOW()
  }

  entity DETALLE_PEDIDO {
    * id : BIGINT <<PK>>
    --
    * pedido_id : BIGINT <<FK>> NOT NULL
    * producto_id : BIGINT <<FK>> NOT NULL
    * cantidad : INTEGER NOT NULL
    * precio_unit : DECIMAL(10,2) NOT NULL
    * subtotal : DECIMAL(12,2) NOT NULL
  }

  entity PRODUCTO {
    * id : BIGINT <<PK>>
    --
    * codigo : VARCHAR(30) NOT NULL UNIQUE
    * nombre : VARCHAR(200) NOT NULL
    * peso_kg : DECIMAL(8,3) NOT NULL
    * volumen_m3 : DECIMAL(8,3) NOT NULL
    * precio_base : DECIMAL(10,2) NOT NULL
    * stock : INTEGER NOT NULL DEFAULT 0
  }

  entity DIRECCION_ENTREGA {
    * id : BIGINT <<PK>>
    --
    * pedido_id : BIGINT <<FK>> NOT NULL UNIQUE
    * calle : VARCHAR(200) NOT NULL
    * distrito : VARCHAR(100) NOT NULL
    * ciudad : VARCHAR(100) NOT NULL
    latitud : DECIMAL(10,7)
    longitud : DECIMAL(10,7)
    * validada : BOOLEAN NOT NULL DEFAULT FALSE
  }

  entity IMPORTACION_CSV {
    * id : BIGINT <<PK>>
    --
    * despachadora_id : BIGINT <<FK>> NOT NULL
    * nombre_archivo : VARCHAR(255) NOT NULL
    * fecha_import : TIMESTAMP NOT NULL DEFAULT NOW()
    * total_registros : INTEGER NOT NULL
    * exitosos : INTEGER NOT NULL DEFAULT 0
    * fallidos : INTEGER NOT NULL DEFAULT 0
    errores : TEXT
  }

  IMPORTACION_CSV ||--o{ PEDIDO
  PEDIDO ||--o{ DETALLE_PEDIDO
  PEDIDO ||--|| DIRECCION_ENTREGA
  PRODUCTO ||--o{ DETALLE_PEDIDO
}

' Enlaces Cruzados: Usuarios -> Pedidos
CLIENTE_MINORISTA ||--o{ PEDIDO
DESPACHADORA ||--o{ PEDIDO
DESPACHADORA ||--o{ IMPORTACION_CSV

' ══════════════════════════════════
' PACKAGE: Flota
' ══════════════════════════════════
package "Flota" #F0FDF4 {
  entity VEHICULO {
    * id : BIGINT <<PK>>
    --
    * placa : VARCHAR(10) NOT NULL UNIQUE
    * marca : VARCHAR(100) NOT NULL
    * capacidad_kg : DECIMAL(8,2) NOT NULL
    * capacidad_m3 : DECIMAL(8,3) NOT NULL
    * estado_vehiculo : VARCHAR(15) NOT NULL DEFAULT 'DISPONIBLE'
    * kilometraje : DECIMAL(10,2) NOT NULL DEFAULT 0
    * tipo_vehiculo : VARCHAR(20) NOT NULL
    * combustible_id : BIGINT <<FK>> NOT NULL
    temperatura_min : DECIMAL(5,2)
    temperatura_max : DECIMAL(5,2)
    tipo_carga : VARCHAR(30)
    * modificado_en : TIMESTAMP NOT NULL DEFAULT NOW()
  }

  entity TIPO_COMBUSTIBLE {
    * id : BIGINT <<PK>>
    --
    * nombre : VARCHAR(50) NOT NULL UNIQUE
    * precio_por_litro : DECIMAL(8,2) NOT NULL
  }

  entity REGISTRO_MANTENIMIENTO {
    * id : BIGINT <<PK>>
    --
    * vehiculo_id : BIGINT <<FK>> NOT NULL
    * tipo : VARCHAR(30) NOT NULL
    * fecha : DATE NOT NULL
    * costo : DECIMAL(10,2) NOT NULL
    * proximo_km : DECIMAL(10,2) NOT NULL
  }

  TIPO_COMBUSTIBLE ||--o{ VEHICULO
  VEHICULO ||--o{ REGISTRO_MANTENIMIENTO
}

' ══════════════════════════════════
' PACKAGE: Rutas
' ══════════════════════════════════
package "Rutas" #FFF7ED {
  entity RUTA {
    * id : BIGINT <<PK>>
    --
    * fecha : DATE NOT NULL
    * estado : VARCHAR(15) NOT NULL DEFAULT 'PROPUESTA'
    distancia_total : DECIMAL(10,2)
    duracion_min : INTEGER
    costo_estimado : DECIMAL(12,2)
    * vehiculo_id : BIGINT <<FK>> NOT NULL
    * conductor_id : BIGINT <<FK>> NOT NULL
    aprobada_por : BIGINT <<FK>>
    aprobada_en : TIMESTAMP
    * creado_en : TIMESTAMP NOT NULL DEFAULT NOW()
    * modificado_en : TIMESTAMP NOT NULL DEFAULT NOW()
  }

  entity PARADA {
    * id : BIGINT <<PK>>
    --
    * ruta_id : BIGINT <<FK>> NOT NULL
    * direccion_id : BIGINT <<FK>> NOT NULL
    * orden : INTEGER NOT NULL
    * eta_estimada : TIMESTAMP NOT NULL
    eta_real : TIMESTAMP
    * estado : VARCHAR(15) NOT NULL DEFAULT 'PENDIENTE'
    latitud : DECIMAL(10,7)
    longitud : DECIMAL(10,7)
  }

  entity PARADA_PEDIDO {
    * parada_id : BIGINT <<FK>>
    * pedido_id : BIGINT <<FK>>
  }

  entity COSTO_RUTA {
    * id : BIGINT <<PK>>
    --
    * ruta_id : BIGINT <<FK>> NOT NULL UNIQUE
    * combustible_soles : DECIMAL(10,2) NOT NULL DEFAULT 0
    * peajes_soles : DECIMAL(10,2) NOT NULL DEFAULT 0
    * viaticos_chofer : DECIMAL(10,2) NOT NULL DEFAULT 0
    * total_soles : DECIMAL(12,2) NOT NULL DEFAULT 0
  }

  entity ZONA_GEOGRAFICA {
    * id : BIGINT <<PK>>
    --
    * nombre : VARCHAR(100) NOT NULL UNIQUE
    * poligono_wkt : TEXT NOT NULL
  }

  entity RESTRICCION_RUTA {
    * id : BIGINT <<PK>>
    --
    * zona_id : BIGINT <<FK>> NOT NULL
    * tipo : VARCHAR(30) NOT NULL
    * hora_inicio : TIME NOT NULL
    * hora_fin : TIME NOT NULL
    * dias_semana : VARCHAR(13) NOT NULL
  }

  entity RUTA_ZONA {
    * ruta_id : BIGINT <<FK>>
    * zona_id : BIGINT <<FK>>
  }

  RUTA ||--|| COSTO_RUTA
  RUTA ||--o{ PARADA
  PARADA_PEDIDO }o--|| PARADA
  PARADA_PEDIDO }o--|| PEDIDO
  ZONA_GEOGRAFICA ||--o{ RESTRICCION_RUTA
  RUTA_ZONA }o--|| RUTA
  RUTA_ZONA }o--|| ZONA_GEOGRAFICA
  PARADA }o-left-|| DIRECCION_ENTREGA
}

' Enlaces Cruzados: Flota/Rutas -> Usuarios
VEHICULO ||--o{ RUTA
CONDUCTOR ||--o{ RUTA
GERENTE_OPERACIONES ||--o{ RUTA

' ══════════════════════════════════
' PACKAGE: GPS y Alertas
' ══════════════════════════════════
package "GPS y Alertas" #FEF2F2 {
  entity REGISTRO_POSICION {
    * id : BIGINT <<PK>>
    --
    * vehiculo_id : BIGINT <<FK>> NOT NULL
    * latitud : DECIMAL(10,7) NOT NULL
    * longitud : DECIMAL(10,7) NOT NULL
    * velocidad : DECIMAL(6,2) NOT NULL
    * timestamp : TIMESTAMP NOT NULL
  }

  entity EVENTO_GPS {
    * id : BIGINT <<PK>>
    --
    * vehiculo_id : BIGINT <<FK>> NOT NULL
    * tipo : VARCHAR(30) NOT NULL
    * timestamp : TIMESTAMP NOT NULL
    * latitud : DECIMAL(10,7) NOT NULL
    * longitud : DECIMAL(10,7) NOT NULL
  }

  entity ALERTA {
    * id : BIGINT <<PK>>
    --
    * ruta_id : BIGINT <<FK>> NOT NULL
    conductor_id : BIGINT <<FK>>
    * tipo : VARCHAR(30) NOT NULL
    * mensaje : TEXT NOT NULL
    * timestamp : TIMESTAMP NOT NULL
    retraso_min : INTEGER
    nuevo_eta : TIMESTAMP
    * resuelta : BOOLEAN NOT NULL DEFAULT FALSE
  }

  entity INCIDENCIA {
    * id : BIGINT <<PK>>
    --
    * conductor_id : BIGINT <<FK>> NOT NULL
    * ruta_id : BIGINT <<FK>> NOT NULL
    * tipo : VARCHAR(50) NOT NULL
    * descripcion : TEXT NOT NULL
    * timestamp : TIMESTAMP NOT NULL
    * resuelta : BOOLEAN NOT NULL DEFAULT FALSE
  }

  VEHICULO ||--o{ REGISTRO_POSICION
  VEHICULO ||--o{ EVENTO_GPS
  RUTA ||--o{ ALERTA
  RUTA ||--o{ INCIDENCIA
}

' Enlaces Cruzados: GPS -> Conductor
CONDUCTOR ||--o{ ALERTA
CONDUCTOR ||--o{ INCIDENCIA

' ══════════════════════════════════
' PACKAGE: Notificaciones
' ══════════════════════════════════
package "Notificaciones" #FDF4FF {
  entity NOTIFICACION {
    * id : BIGINT <<PK>>
    --
    * pedido_id : BIGINT <<FK>> NOT NULL
    * cliente_id : BIGINT <<FK>> NOT NULL
    * tipo : VARCHAR(20) NOT NULL
    * estado : VARCHAR(15) NOT NULL DEFAULT 'PENDIENTE'
    * mensaje : TEXT NOT NULL
    * enviada_en : TIMESTAMP NOT NULL DEFAULT NOW()
    * intentos : INTEGER NOT NULL DEFAULT 0
    * canal : VARCHAR(10) NOT NULL
    numero_destino : VARCHAR(20)
    email_destino : VARCHAR(150)
    asunto : VARCHAR(200)
    template_id : VARCHAR(50)
    message_id : VARCHAR(100)
  }

  entity LOG_NOTIFICACION {
    * id : BIGINT <<PK>>
    --
    * notificacion_id : BIGINT <<FK>> NOT NULL
    * canal : VARCHAR(10) NOT NULL
    * estado : VARCHAR(20) NOT NULL
    * timestamp : TIMESTAMP NOT NULL
    * duplicado_evitado : BOOLEAN NOT NULL DEFAULT FALSE
  }

  PEDIDO ||--o{ NOTIFICACION
  NOTIFICACION ||--o{ LOG_NOTIFICACION
}

CLIENTE_MINORISTA ||--o{ NOTIFICACION

' ══════════════════════════════════
' PACKAGE: Analytics
' ══════════════════════════════════
package "Analytics" #FAF5FF {
  entity KPI_DIARIO {
    * id : BIGINT <<PK>>
    --
    * fecha : DATE NOT NULL UNIQUE
    * pct_entregas_a_tiempo : DECIMAL(5,2) NOT NULL
    * total_pedidos : INTEGER NOT NULL DEFAULT 0
    * entregados : INTEGER NOT NULL DEFAULT 0
    * fallidos : INTEGER NOT NULL DEFAULT 0
    * combustible_total : DECIMAL(12,2) NOT NULL DEFAULT 0
  }

  entity DESEMPENO_CONDUCTOR {
    * id : BIGINT <<PK>>
    --
    * conductor_id : BIGINT <<FK>> NOT NULL
    * kpi_id : BIGINT <<FK>> NOT NULL
    * fecha : DATE NOT NULL
    * entregas_completadas : INTEGER NOT NULL DEFAULT 0
    * km_recorridos : DECIMAL(10,2) NOT NULL DEFAULT 0
    * combustible_usado : DECIMAL(8,2) NOT NULL DEFAULT 0
    calificacion : DECIMAL(3,2) DEFAULT 5.0
  }

  entity REPORTE {
    * id : BIGINT <<PK>>
    --
    * gerente_id : BIGINT <<FK>> NOT NULL
    * tipo : VARCHAR(30) NOT NULL
    * fecha_desde : DATE NOT NULL
    * fecha_hasta : DATE NOT NULL
    * formato : VARCHAR(10) NOT NULL
    * generado_en : TIMESTAMP NOT NULL DEFAULT NOW()
    url_archivo : VARCHAR(500)
  }

  entity REPORTE_KPI {
    * reporte_id : BIGINT <<FK>>
    * kpi_id : BIGINT <<FK>>
  }

  KPI_DIARIO ||--o{ DESEMPENO_CONDUCTOR
  REPORTE_KPI }o--|| REPORTE
  REPORTE_KPI }o--|| KPI_DIARIO
}

CONDUCTOR ||--o{ DESEMPENO_CONDUCTOR
GERENTE_OPERACIONES ||--o{ REPORTE

@enduml 